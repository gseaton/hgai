# HypergraphAI Environment Configuration
# Copy this file to .env and edit as needed

# ─── MongoDB ────────────────────────────────────────────────────────────────
HGAI_MONGO_URI=mongodb://admin:pwd357@localhost:27017/hgai?authSource=admin
HGAI_MONGO_DB=hgai

# ─── Security ───────────────────────────────────────────────────────────────
# REQUIRED: Change this to a strong random secret in production
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
HGAI_SECRET_KEY=change-me-to-a-strong-random-secret-key-in-production
HGAI_TOKEN_EXPIRE_MINUTES=480

# ─── Server ─────────────────────────────────────────────────────────────────
HGAI_HOST=0.0.0.0
HGAI_PORT=8000
HGAI_LOG_LEVEL=info
HGAI_RELOAD=false

# ─── Server Identity (for mesh operations) ──────────────────────────────────
HGAI_SERVER_ID=hgai-local
HGAI_SERVER_NAME=HypergraphAI Local

# ─── Query Cache ────────────────────────────────────────────────────────────
HGAI_CACHE_ENABLED=true
HGAI_CACHE_TTL_SECONDS=300
HGAI_CACHE_MAX_SIZE=1000

# ─── CORS ───────────────────────────────────────────────────────────────────
HGAI_CORS_ORIGINS=*

# ─── Admin Bootstrap ────────────────────────────────────────────────────────
# Used only on first run to create the admin account
HGAI_ADMIN_USERNAME=admin
HGAI_ADMIN_PASSWORD=pwd357
HGAI_ADMIN_EMAIL=admin@hgai.local
